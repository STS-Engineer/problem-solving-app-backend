DATABASE_URL =
SECRET_KEY=

# Set to false in local development to disable ALL background jobs
# (escalation checks, email retries, webhook delivery, nightly prune) so a
# local process does not act against the shared DB.
# Leave unset / true in deployed (Azure) environments.
ENABLE_SCHEDULER=true

# ── Azure Blob Storage (escalation-action attachments) ──────────────────────
# Full connection string from the storage account (Access keys blade).
AZURE_CONNECTION_STRING=
# Container that will hold escalation attachments (created automatically).
AZURE_STORAGE_CONTAINER_NAME=



