{
  "openapi": "3.0.3",
  "info": {
    "title": "AVOCarbon Email Intake API",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "https://complaint-back.azurewebsites.net",
      "description": "Azure backend"
    }
  ],
  "paths": {
    "/api/v1/intake/email": {
      "post": {
        "tags": ["email-intake"],
        "summary": "Register a complaint received by email",
        "description": "Idempotent intake of a complaint email. Dedups on source_message_id and attaches follow-ups on conversation_id. Only source_message_id is required; send everything the email provides.",
        "operationId": "createComplaintIntake",
        "security": [{ "IntakeKey": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EmailIntakeCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Intake created (or duplicate / attached_to_existing)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EmailIntakeResult" }
              }
            }
          },
          "401": { "description": "Invalid or missing X-Intake-Key" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/api/v1/intake": {
      "get": {
        "tags": ["email-intake"],
        "summary": "List email intakes",
        "description": "List intakes, filtered by status.",
        "operationId": "listIntakes",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["pending_review", "promoted", "rejected", "duplicate"],
              "default": "pending_review"
            }
          },
          {
            "name": "skip",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0, "default": 0 }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "Intake list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/EmailIntakeListItem" }
                }
              }
            }
          },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/api/v1/complaints": {
      "get": {
        "tags": ["complaints"],
        "summary": "List Complaints",
        "description": "List complaints with optional filters.",
        "operationId": "listComplaints",
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0, "default": 0 }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 50 }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "product_line",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["ASSEMBLY", "BRUSH", "CHOKE", "SEAL", "FRICTION"]
            }
          },
          {
            "name": "cqt_email",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Complaint list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ComplaintListItem" }
                }
              }
            }
          },
          "422": { "description": "Validation error" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "IntakeKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Intake-Key"
      }
    },
    "schemas": {
      "PlantEnum": {
        "type": "string",
        "enum": [
          "MONTERREY",
          "KUNSHAN",
          "CHENNAI",
          "DAEGU",
          "TIANJIN",
          "POITIERS",
          "FRANKFURT",
          "SCEET",
          "SAME",
          "AMIENS",
          "ANHUI",
          "KOREA",
          "NADHOUR"
        ]
      },
      "ExtractedData": {
        "type": "object",
        "additionalProperties": true,
        "description": "Complaint fields the agent extracts from the email/attachments. None are strictly required by the API (lenient staging), but ALL of the following are needed for the backend to auto-create the complaint without human help: complaint_name, customer, customer_plant_name, avocarbon_plant, avocarbon_product_type, product_line, quality_issue_warranty, potential_avocarbon_process_linked_to_problem, defects, complaint_description, customer_complaint_date. Controlled fields MUST use one of the listed values (case-insensitive) or they count as missing.",
        "properties": {
          "complaint_name": {
            "type": "string",
            "description": "Short title of the problem, e.g. 'Crack after welding'."
          },
          "complaint_description": {
            "type": "string",
            "description": "Full description: what was observed, when, on which part, quantity, customer impact."
          },
          "customer": {
            "type": "string",
            "description": "Customer name. Prefer an exact match from: VALEO, INTEVA, DENSO, KELI, NIDEC, MAHLE, HELLA, HAYWARD, ADVIK, DOLZ, BOSCH, E-MOTOR, BMW, VW, PHINIA, BOSCH POWERTOOL, STANLEY - BLACK AND DECKER, RUIDONG, BYD, KOSTAL, RENAULT, MIMZHEN, BORGWANER, TESLA, US MOTOR WORKS, AUDI, SPECK, PIERBURG, BUEHLER, CEBI, YAMAHA, ELEKTRA, RÖMER, EUROTEC, Tianjin Yixin, Tiang Long, Rui Wei, Li Shui Qiangrun, Ji Ou, Lang Xin, Jiang Su Yun Tai, Kinetic, Zhuo Ren, Dong Jiang, Wu Zhou Ren Xin, Guangzhou Hua Wang, Xuan Pu, Fine-World. If not in the list, send the raw name anyway (a human will complete it)."
          },
          "customer_plant_name": {
            "type": "string",
            "description": "The customer's plant/site, e.g. 'Renault Flins'."
          },
          "avocarbon_plant": {
            "allOf": [{ "$ref": "#/components/schemas/PlantEnum" }],
            "description": "The responsible AVOCarbon plant. Also drives notification routing."
          },
          "avocarbon_product_type": {
            "type": "string",
            "description": "AVOCarbon product type, e.g. CHOKE, BRUSH, SLIP RING, HARNESS, SOLENOIDE, etc."
          },
          "product_line": {
            "type": "string",
            "enum": ["ASSEMBLY", "BRUSH", "CHOKE", "SEAL", "FRICTION"],
            "description": "AVOCarbon product line."
          },
          "quality_issue_warranty": {
            "type": "string",
            "enum": ["CS2", "CS1", "WR", "Quality Alert"],
            "description": "Claim type / severity. CS2 = critical, CS1 = major, WR = warranty."
          },
          "potential_avocarbon_process_linked_to_problem": {
            "type": "string",
            "enum": [
              "ASSEMBLY", "TESTING", "WINDING", "GLUING", "BAKING", "GRINDING",
              "PILLING", "CRIMPING", "WELDING", "SOLDERING", "INSPECTION",
              "PLASTIC INJECTION", "PLASTIC DEFLASHING", "PRODUCT TREACEABILITY",
              "SHIPPING", "LAPPING", "TAMPING"
            ],
            "description": "Manufacturing process likely linked to the problem."
          },
          "defects": {
            "type": "string",
            "enum": ["Function", "Fit", "Dimensional", "Appearance"],
            "description": "Defect category."
          },
          "customer_complaint_date": {
            "type": "string",
            "format": "date",
            "description": "Date the customer raised the complaint (YYYY-MM-DD)."
          },
          "concerned_application": {
            "type": "string",
            "description": "Optional. End application, e.g. FRONT WIPER, STARTER, WINDOW LIFT."
          },
          "repetitive_complete_with_number": {
            "type": "string",
            "description": "Optional. Number of prior occurrences ('0' if first time)."
          }
        }
      },
      "AttachmentIn": {
        "type": "object",
        "required": ["filename"],
        "description": "One email attachment. For real files, ALWAYS send download_url (the Microsoft Graph signed download URL from the Outlook connector) — the backend downloads and stores the file at ingestion. Do NOT send base64. Set is_inline=true for embedded images (signatures/logos): they are skipped. Analyze each file and provide a short human description; if the file contains complaint information (the complaint may be entirely inside an attachment), also extract it into extracted_data.",
        "properties": {
          "filename": { "type": "string" },
          "mime_type": { "type": "string", "nullable": true },
          "size": { "type": "integer", "nullable": true, "description": "Size in bytes if known" },
          "download_url": {
            "type": "string",
            "nullable": true,
            "description": "Short-lived signed download URL (MS Graph). The backend fetches it immediately, so send it fresh."
          },
          "url": {
            "type": "string",
            "nullable": true,
            "description": "Fallback: an already-hosted durable URL, used only if download_url is absent."
          },
          "sha256": { "type": "string", "nullable": true, "description": "SHA-256 hex for integrity verification" },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Short description of the file's content, e.g. 'Customer 8D report PDF', 'Photo of cracked part', 'Excel measurement data'."
          },
          "is_inline": {
            "type": "boolean",
            "description": "True for inline/embedded images (signatures, logos) — skipped by the backend.",
            "default": false
          },
          "content_id": { "type": "string", "nullable": true }
        }
      },
      "EmailIntakeCreate": {
        "type": "object",
        "required": ["source_message_id"],
        "properties": {
          "source_message_id": {
            "type": "string",
            "maxLength": 998,
            "description": "A STABLE, UNIQUE id for this email — the dedup key. Prefer the RFC 5322 Message-ID (internetMessageId) if the connector exposes it; otherwise use the Outlook/Microsoft Graph message id (also stable and unique). ALWAYS send the SAME id for the same email so re-processing is idempotent."
          },
          "conversation_id": {
            "type": "string",
            "maxLength": 512,
            "nullable": true,
            "description": "Mail thread id — the Outlook/Graph conversationId. Send it so follow-up emails on the same thread attach to the same complaint."
          },
          "sender_email": {
            "type": "string",
            "maxLength": 255,
            "nullable": true,
            "description": "The email envelope From address (who sent the claim)."
          },
          "sender_name": { "type": "string", "maxLength": 255, "nullable": true },
          "subject": { "type": "string", "maxLength": 998, "nullable": true },
          "received_at": { "type": "string", "format": "date-time", "nullable": true },
          "raw_body": {
            "type": "string",
            "nullable": true,
            "description": "Plain-text body of the email."
          },
          "raw_html": { "type": "string", "nullable": true },
          "attachments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AttachmentIn" }
          },
          "extracted_data": {
            "allOf": [{ "$ref": "#/components/schemas/ExtractedData" }],
            "description": "Complaint fields extracted from the email AND its attachments. Fill as many as the source provides. If the required fields are all valid the backend auto-creates the complaint; otherwise a human completes it. Read attachments too — the complaint is sometimes entirely inside a PDF/Excel."
          },
          "ai_notes": {
            "type": "string",
            "nullable": true,
            "description": "Notes on what could not be determined."
          },
          "missing_fields": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Names of required fields the email did not provide."
          },
          "detected_plant": {
            "allOf": [{ "$ref": "#/components/schemas/PlantEnum" }],
            "nullable": true,
            "description": "Set only if confidently identified; otherwise omit and it falls back to triage."
          }
        }
      },
      "EmailIntakeResult": {
        "type": "object",
        "required": ["status", "intake_id"],
        "description": "Result of registering the email. Report status and intake_id back to the user.",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["created", "duplicate", "attached_to_existing"],
            "description": "created = new intake stored; duplicate = same Message-ID already ingested (no-op); attached_to_existing = follow-up attached to an open thread."
          },
          "intake_id": {
            "type": "integer",
            "description": "ID of the intake row — use it to fetch, assign a CQT, or promote."
          },
          "notified_to": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Emails notified (plant QM/PM, or the triage fallback if the plant is unknown)."
          }
        }
      },
      "EmailIntakeListItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "source_message_id": { "type": "string" },
          "sender_email": { "type": "string", "nullable": true },
          "sender_name": { "type": "string", "nullable": true },
          "subject": { "type": "string", "nullable": true },
          "detected_plant": { "type": "string", "nullable": true },
          "status": { "type": "string" },
          "missing_fields": {
            "type": "array",
            "items": { "type": "string" }
          },
          "assigned_cqe_email": { "type": "string", "nullable": true },
          "complaint_id": { "type": "integer", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ComplaintListItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "reference_number": { "type": "string" },
          "complaint_name": { "type": "string" },
          "customer": { "type": "string", "nullable": true },
          "customer_plant_name": { "type": "string", "nullable": true },
          "avocarbon_product_type": { "type": "string", "nullable": true },
          "concerned_application": { "type": "string", "nullable": true },
          "product_line": { "type": "string" },
          "avocarbon_plant": { "type": "string", "nullable": true },
          "status": { "type": "string" },
          "quality_issue_warranty": { "type": "string", "nullable": true },
          "defects": { "type": "string", "nullable": true },
          "customer_complaint_date": { "type": "string", "format": "date", "nullable": true },
          "complaint_opening_date": { "type": "string", "format": "date", "nullable": true },
          "repetitive_complete_with_number": { "type": "string", "nullable": true },
          "complaint_description": { "type": "string", "nullable": true },
          "potential_avocarbon_process_linked_to_problem": { "type": "string", "nullable": true },
          "closed_at": { "type": "string", "format": "date-time", "nullable": true },
          "current_step_code": { "type": "string", "nullable": true },
          "all_completed": { "type": "boolean" },
          "has_report": { "type": "boolean" },
          "has_export_report": { "type": "boolean" },
          "is_overdue": { "type": "boolean", "nullable": true },
          "cqt_email": { "type": "string", "nullable": true },
          "quality_manager_email": { "type": "string", "nullable": true },
          "plant_manager_email": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
 